# --- Adapters: proveedores LLM usados por tus casos de evaluacion ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Grader llmJudge: modelo usado como juez (por defecto usa ANTHROPIC_API_KEY) ---
PROMPTPROOF_JUDGE_MODEL=claude-sonnet-5

# --- Persistencia ---
# Ruta del fichero SQLite local (por defecto: ./promptproof.db)
PROMPTPROOF_DB_PATH=./promptproof.db
# Si se define, la CLI y el dashboard usan Postgres en vez de SQLite
DATABASE_URL=

# --- GitHub Action / CI ---
# Referencia (branch, tag o commit) usada como baseline para el gating de regresion
PROMPTPROOF_BASELINE_REF=main

# --- Dashboard (packages/dashboard) ---
VITE_PROMPTPROOF_API_URL=http://localhost:4000
