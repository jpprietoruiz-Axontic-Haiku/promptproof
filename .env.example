# --- Adapters: LLM providers used by your eval cases ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- llmJudge grader: model used as the judge (defaults to using ANTHROPIC_API_KEY) ---
PROMPTPROOF_JUDGE_MODEL=claude-sonnet-5

# --- Persistence ---
# Local SQLite file path (defaults to ./promptproof.db)
PROMPTPROOF_DB_PATH=./promptproof.db
# If set, the CLI and dashboard use Postgres instead of SQLite
DATABASE_URL=

# --- GitHub Action / CI ---
# Ref (branch, tag, or commit) used as the baseline for regression gating
PROMPTPROOF_BASELINE_REF=main

# --- Dashboard (packages/dashboard) ---
VITE_PROMPTPROOF_API_URL=http://localhost:4000
